{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Payment",
  "type": "object",
  "properties": {
    "Id": {
      "type": "string"
    },
    "SyncToken": {
      "type": "string"
    },
    "TxnDate": {
      "type": "string"
    },
    "TotalAmt": {
      "type": "number"
    },
    "PaymentRefNum": {
      "type": "string"
    },
    "ExchangeRate": {
      "type": "number"
    },
    "Line": {
      "type": "array"
    },
    "PrivateNote": {
      "type": "string"
    },
    "UnappliedAmt": {
      "type": "number"
    },
    "ProcessPayment": {
      "type": "boolean"
    },
    "TxnSource": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "sparse": {
      "type": "boolean"
    }
  }
}